# Local single-machine play can leave this empty and use the default dev no-auth mode.
# Set a strong value here when binding beyond 127.0.0.1 or sharing the instance.
REFEREE_API_KEY=
# Local compose defaults to 1. Set 0 in shared environments.
REFEREE_ALLOW_INSECURE_NO_AUTH=1
# Dangerous escape hatch: only set to 1 if you intentionally expose a no-auth
# instance beyond localhost on a trusted/private machine.
REFEREE_ALLOW_SHARED_NO_AUTH=0
# Local compose binds both frontend and referee to localhost by default.
# Use 0.0.0.0 only together with a strong REFEREE_API_KEY in shared environments.
FRONTEND_BIND_HOST=127.0.0.1
REFEREE_BIND_HOST=127.0.0.1
# Browser WebSocket auth uses /api/ws-ticket by default. Only enable for legacy local clients.
REFEREE_ALLOW_WS_API_KEY_QUERY=0
# Allows /api/test-llm to reach localhost/private IP endpoints. Keep disabled
# unless you intentionally test an internal or local LLM gateway.
REFEREE_ALLOW_PRIVATE_OUTBOUND_URLS=0
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# 0 disables automatic pruning. Set a positive number to opt into history cleanup.
OPENCLAW_MATCH_RETENTION_DAYS=0

# Optional AI live commentator. Leave disabled unless a separate commentary
# model endpoint is configured.
COMMENTATOR_ENABLED=0
COMMENTATOR_PROVIDER=openai-completions
COMMENTATOR_MODEL=
COMMENTATOR_API_KEY=
COMMENTATOR_BASE_URL=
COMMENTATOR_INTERVAL_SECONDS=20
COMMENTATOR_MAX_LOG_CHARS=4000
