FROM node:20-alpine

RUN apk add --no-cache \
    python3 \
    sqlite \
    openssh-server \
    curl \
    bash

RUN mkdir /var/run/sshd && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    echo "AllowUsers juice" >> /etc/ssh/sshd_config

RUN adduser -D -s /bin/bash juice && \
    echo "juice:changeme" | chpasswd

RUN mkdir -p /app/arena && \
    chown -R juice:juice /app/arena

WORKDIR /app

RUN echo '<!DOCTYPE html><html><body><h1>OpenClaw AWD Target</h1></body></html>' > index.html

COPY init_arena_db.sql /app/arena/
COPY docker-entrypoint-test.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 3000 22

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3000/ || exit 1

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
